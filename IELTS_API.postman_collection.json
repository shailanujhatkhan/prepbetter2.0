              "raw": "{\n  \"band_score\": 7.5,\n  \"grammar_feedback\": \"Excellent range of complex structures used accurately throughout.\",\n  \"vocabulary_feedback\": \"Sophisticated vocabulary with precise word choice and minimal errors.\",\n  \"coherence_feedback\": \"Logically organised with a clear central topic in each paragraph.\",\n  \"recommendations\": \"Focus on varying sentence openings and check subject-verb agreement in longer sentences.\"\n}",
