              "raw": "{\n  \"band_score\": 7.0,\n  \"grammar_feedback\": \"Good range of grammatical structures with generally accurate usage. Minor issues with article usage in a few places.\",\n  \"vocabulary_feedback\": \"Effective use of topic-specific vocabulary such as upward trend and year-on-year increase. Good range of synonyms.\",\n  \"coherence_feedback\": \"Well organised with clear progression. Good use of cohesive devices. Each paragraph has a clear focus.\",\n  \"recommendations\": \"Try to include more specific data points and comparisons. Consider using more complex sentence structures to aim for a higher band score.\"\n}",
              "options": { "raw": { "language": "json" } }
