              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"In today's rapidly evolving society, the debate around technology's role in the workplace has intensified. While many argue that technological advancements have significantly boosted productivity, others contend that they bring considerable stress and undermine meaningful human interaction. I believe that technology, when managed effectively, offers far more benefits than drawbacks.\\n\\nOn one hand, technology has revolutionised workplace efficiency. Digital communication tools such as email and video conferencing allow teams to collaborate seamlessly across different time zones. Furthermore, automation of repetitive tasks frees employees to focus on creative and strategic work, leading to higher overall output. For example, project management software has reduced the time spent in status meetings by enabling real-time progress tracking.\\n\\nOn the other hand, critics argue that technology contributes to employee burnout. The expectation of constant availability through smartphones and messaging apps means that the boundary between work and personal life has blurred. Studies indicate that employees who feel obligated to check emails outside working hours report significantly higher stress levels.\\n\\nOverall, while technology does introduce challenges related to work-life balance, these are largely addressable through clear organisational policies. The productivity gains and collaborative opportunities it provides are transformative. Companies that establish healthy digital boundaries can harness the full potential of technology while protecting employee well-being.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/writing/5/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "writing", "5", "submit"]
            }
          }
